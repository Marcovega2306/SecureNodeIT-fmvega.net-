# Copia este archivo a .env.local y ajusta los valores.

# === Supabase (self-hosted) ===
# Gateway (Kong) de tu instancia. Público: se envía al navegador.
NEXT_PUBLIC_SUPABASE_URL="http://localhost:8000"
# anon key (pública).
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# service_role key (SECRETA — solo servidor). Nunca en una var NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=""

# Email del único admin (allowlist, decisión #4). Solo este email accede a /admin.
ADMIN_EMAIL="admin@fmvega.net"
